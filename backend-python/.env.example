# ==========================================
# MindCare 心理陪伴助手 — Python 后端配置
# 复制为 .env 并填入真实值
# ==========================================

APP_NAME=mental-companion-assistant-python
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# ---- MySQL ----
MYSQL_URL=mysql+pymysql://root:1111@127.0.0.1:3307/mental_companion?charset=utf8mb4

# ---- Redis ----
REDIS_URL=redis://127.0.0.1:6379/0

# ---- JWT ----
JWT_SECRET=your-jwt-secret-change-me
JWT_EXPIRE_MINUTES=720

# ---- LLM (阿里云百炼 DashScope / OpenAI-compatible) ----
LLM_PROVIDER=openai
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
LLM_API_KEY=sk-your-api-key
LLM_MODEL=qwen-plus
LLM_VISION_MODEL=qwen-vl-plus
LLM_EMBEDDING_MODEL=text-embedding-v3

# ---- 多模态上传限制 ----
MAX_IMAGE_SIZE_MB=10
MAX_MEDIA_COUNT=5
MEDIA_UPLOAD_DIR=./data/uploads
MEDIA_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif,image/webp

# ---- Qdrant 向量数据库 ----
# text-embedding-v3 输出 1024 维向量，如用其他嵌入模型请按实际维度调整
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=mental_companion_knowledge
QDRANT_VECTOR_SIZE=1024

# ---- RAG 混合检索 ----
RAG_FINAL_TOP_K=3
RAG_DENSE_TOP_K=12
RAG_KEYWORD_TOP_K=12
RAG_RRF_K=60
RERANKER_ENABLED=false
CROSS_ENCODER_MODEL=BAAI/bge-reranker-base

# ---- Excel 记录 ----
EXCEL_WORKFLOW_PATH=./data/workflow-records.xlsx
EXCEL_EXPORT_DIR=./data/exported

# ---- 邮件预警 (QQ邮箱 SMTP) ----
MAIL_ENABLED=false
MAIL_HOST=smtp.qq.com
MAIL_PORT=465
MAIL_USERNAME=your-email@qq.com
MAIL_PASSWORD=your-smtp-auth-code
MAIL_FROM=your-email@qq.com
MAIL_ALERT_RECEIVER=admin@example.com
MAIL_USE_SSL=true
MAIL_USE_TLS=false
MAIL_TEACHER_NAME=李老师
MAIL_TEACHER_DEPARTMENT=学生心理健康中心

# ---- 微调（可选）----
FINE_TUNE_ENABLED=false
FINE_TUNE_BASE_MODEL=Qwen2.5
FINE_TUNE_ADAPTER_TYPE=QLoRA
FINE_TUNE_ADAPTER_PATH=./models/adapters/qwen2.5-mental
FINE_TUNE_OLLAMA_MODEL=qwen2.5-mental:latest
FINE_TUNE_TRAINING_PROFILE=emotion-dialog-sft
